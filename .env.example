# ─────────────────────────────────────────────
# Cubmaster Dashboard — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# App
SECRET_KEY=change-me-to-a-long-random-string   # openssl rand -hex 32
PACK_NUMBER=44
PACK_LOCATION=Philipsburg, PA

# Database (SQLite default — path inside the Docker volume)
DATABASE_URL=sqlite:////data/cubmaster.db
# Postgres alternative: postgresql://user:pass@host:5432/cubmaster

# Band iCal feed URL
# In Band: go to your group calendar → Export → copy the .ics link
ICAL_URL=https://band.us/your-calendar-link.ics
# How often to poll for new events (minutes)
ICAL_POLL_INTERVAL=120

# Email (any SMTP — Gmail, Fastmail, your own server, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Pack 44 <you@example.com>

# Alert lead times (days before event to send reminder)
ALERT_LEAD_DAYS=7,3,1

# SMS via Twilio (optional — leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
